<mujoco model="Phonebot_URDF_v2">
  <default>
    <default class="robot">
      <default class="motor">
        <!-- Torque-controlled servo model (XL430-family proxy).
             Joint passive terms are tuned to ToddlerBot's 2XL430 sysID values. -->
        <joint stiffness="0" damping="0.0013" frictionloss="0.069" armature="0.0083" />
        <!-- Motor actuator: ctrl is torque (Nm). Keep ctrlrange wide; clamp in controller code. -->
        <motor ctrlrange="-10 10" />
      </default>
      <default class="visual">
        <geom material="visualgeom" contype="0" conaffinity="0" group="2" />
      </default>
      <default class="collision">
      <!-- note that contype="1" conaffinity="1" is for the body able to collide with each other , not only with the feet and ground, -->
       <!-- but in the contact pair, the collision between two pairs that is connected are removed  -->
        <geom material="collision_material" condim="3" contype="1" conaffinity="1" priority="1" group="1" solref="0.005 1"
              solimp="0.99 0.999 1e-05" friction="1 0.01 0.01" />
      </default>
    </default>
  </default>

